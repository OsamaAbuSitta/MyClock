<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:MyClock.App.ViewModels"
        x:Class="MyClock.App.Views.SettingsWindow"
        x:DataType="vm:SettingsWindowViewModel"
        Title="Settings"
        Width="400"
        SizeToContent="Height"
        CanResize="False"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="False"
        FontSize="14">

    <Window.Styles>
        <Style Selector="TextBlock">
            <Setter Property="FontSize" Value="14"/>
        </Style>
        <Style Selector="ToggleSwitch">
            <Setter Property="FontSize" Value="14"/>
        </Style>
    </Window.Styles>

    <StackPanel Margin="20" Spacing="10">

        <!-- Clock visibility -->
        <TextBlock Text="Clock" FontWeight="SemiBold"/>
        <ToggleSwitch IsChecked="{Binding ShowClock}"
                      OnContent="Visible" OffContent="Hidden"/>

        <!-- Time Format -->
        <TextBlock Text="Time Format" FontWeight="SemiBold" Margin="0 4 0 0"/>
        <ToggleSwitch IsChecked="{Binding Use24HourFormat}"
                      IsEnabled="{Binding ShowClock}"
                      OnContent="24-hour" OffContent="12-hour"/>

        <!-- Opacity -->
        <TextBlock Text="Widget Opacity" Margin="0 6 0 0"/>
        <Slider Minimum="0.3" Maximum="1.0"
                Value="{Binding Opacity}"
                TickFrequency="0.05"
                IsSnapToTickEnabled="True"/>

        <Separator Margin="0 4"/>

        <!-- Timer Mode -->
        <TextBlock Text="Timer Mode" FontWeight="SemiBold"/>
        <StackPanel Spacing="6">
            <RadioButton Content="Free Mode"
                         IsChecked="{Binding IsFreeMode}"
                         FontSize="14"/>
            <RadioButton Content="Session Set Mode"
                         IsChecked="{Binding IsSessionSetMode}"
                         FontSize="14"/>
        </StackPanel>

        <!-- Session Set options (only when Session Set Mode) -->
        <StackPanel IsVisible="{Binding IsSessionSetMode}" Spacing="8" Margin="0 4 0 0">
            <TextBlock Text="Active Set" FontWeight="SemiBold"/>
            <ComboBox ItemsSource="{Binding SessionSets}"
                      SelectedItem="{Binding SelectedSessionSet}"
                      DisplayMemberBinding="{Binding Name}"
                      HorizontalAlignment="Stretch"
                      FontSize="14"/>
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Content="Manage Sets..."
                        Command="{Binding ManageSetsCommand}"
                        FontSize="13" Padding="10 5"/>
                <Button Content="Restore Defaults"
                        Command="{Binding RestoreDefaultsCommand}"
                        FontSize="13" Padding="10 5"/>
            </StackPanel>
        </StackPanel>

        <Separator Margin="0 4"/>

        <!-- Save / Cancel -->
        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Spacing="8">
            <Button Content="Cancel" Command="{Binding CancelCommand}" FontSize="14" Padding="12 6"/>
            <Button Content="Save"   Command="{Binding SaveCommand}"
                    Classes="accent" FontSize="14" Padding="12 6"/>
        </StackPanel>

    </StackPanel>
</Window>
