<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:MyClock.App.ViewModels"
        x:Class="MyClock.App.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Width="230" Height="180"
        MinWidth="230" MinHeight="180"
        MaxWidth="230" MaxHeight="180"
        Icon="avares://MyClock.App/Assets/app-icon.png"
        CanResize="False"
        Topmost="True"
        SystemDecorations="None"
        Background="Transparent"
        TransparencyLevelHint="Transparent"
        ExtendClientAreaToDecorationsHint="True">

    <Window.Styles>
        <!-- Ghost: ⚙ × -->
        <Style Selector="Button.ghost">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#55667799"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="4 2"/>
            <Setter Property="CornerRadius" Value="4"/>
        </Style>
        <Style Selector="Button.ghost:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#22FFFFFF"/>
            <Setter Property="Foreground" Value="#CCDDEEFF"/>
        </Style>
        <Style Selector="Button.ghost:pressed /template/ ContentPresenter">
            <Setter Property="Background" Value="#11FFFFFF"/>
        </Style>

        <!-- Shared pill base -->
        <Style Selector="Button.pill">
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Padding" Value="10 4"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <!-- Green: Start / Resume / Next -->
        <Style Selector="Button.green">
            <Setter Property="Background" Value="#4ADE80"/>
            <Setter Property="Foreground" Value="#0A1A0F"/>
        </Style>
        <Style Selector="Button.green:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#22DD66"/>
        </Style>
        <Style Selector="Button.green:pressed /template/ ContentPresenter">
            <Setter Property="Background" Value="#16A34A"/>
        </Style>

        <!-- Orange: Pause -->
        <Style Selector="Button.orange">
            <Setter Property="Background" Value="#FB923C"/>
            <Setter Property="Foreground" Value="#1A0C00"/>
        </Style>
        <Style Selector="Button.orange:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#F97316"/>
        </Style>
        <Style Selector="Button.orange:pressed /template/ ContentPresenter">
            <Setter Property="Background" Value="#EA6C10"/>
        </Style>

        <!-- Grey: Reset -->
        <Style Selector="Button.grey">
            <Setter Property="Background" Value="#2E2E42"/>
            <Setter Property="Foreground" Value="#9999BB"/>
        </Style>
        <Style Selector="Button.grey:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#3A3A52"/>
        </Style>
        <Style Selector="Button.grey:pressed /template/ ContentPresenter">
            <Setter Property="Background" Value="#252538"/>
        </Style>
    </Window.Styles>

    <!-- Outer shell: clipped rounded card -->
    <Border CornerRadius="14"
            ClipToBounds="True"
            PointerPressed="OnDragBorderPressed"
            PointerMoved="OnDragBorderMoved"
            PointerReleased="OnDragBorderReleased">

        <Grid RowDefinitions="3,*">

            <!-- Accent bar -->
            <Border Grid.Row="0" Background="#6C5CE7"/>

            <!-- Main body -->
            <Border Grid.Row="1"
                    Background="#EE141420">

                <StackPanel Margin="12 6 12 10" Spacing="2">

                    <!-- Row 1: clock + icon buttons -->
                    <Grid ColumnDefinitions="*,Auto,Auto">
                        <TextBlock Grid.Column="0"
                                   Text="{Binding CurrentTimeDisplay}"
                                   IsVisible="{Binding ShowClock}"
                                   FontSize="15"
                                   FontWeight="Light"
                                   Foreground="#6677AACC"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Left"/>
                        <Button Grid.Column="1"
                                Classes="ghost"
                                Content="⚙"
                                Command="{Binding OpenSettingsCommand}"
                                FontSize="13"
                                VerticalAlignment="Center"/>
                        <Button Grid.Column="2"
                                Classes="ghost"
                                Content="✕"
                                Command="{Binding CloseCommand}"
                                FontSize="11"
                                VerticalAlignment="Center"/>
                    </Grid>

                    <!-- Row 2: timer -->
                    <TextBlock Text="{Binding SessionTimeDisplay}"
                               FontSize="44"
                               FontWeight="Bold"
                               Foreground="#F0F0FF"
                               HorizontalAlignment="Center"
                               LetterSpacing="-1"
                               Margin="0 2 0 0"/>

                    <!-- Row 3: status -->
                    <TextBlock Text="{Binding SessionStatusDisplay}"
                               FontSize="10"
                               Foreground="#5566889A"
                               HorizontalAlignment="Center"
                               TextTrimming="CharacterEllipsis"
                               MaxWidth="210"/>

                    <!-- Row 4: buttons -->
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                Spacing="5"
                                Margin="0 6 0 0">
                        <Button Classes="pill green"
                                Content="Start"
                                Command="{Binding StartCommand}"
                                IsVisible="{Binding CanStart}"/>
                        <Button Classes="pill orange"
                                Content="Pause"
                                Command="{Binding PauseCommand}"
                                IsVisible="{Binding CanPause}"/>
                        <Button Classes="pill green"
                                Content="Resume"
                                Command="{Binding ResumeCommand}"
                                IsVisible="{Binding CanResume}"/>
                        <Button Classes="pill grey"
                                Content="Reset"
                                Command="{Binding ResetCommand}"
                                IsVisible="{Binding CanReset}"/>
                        <Button Classes="pill green"
                                Content="Next ›"
                                Command="{Binding GoNextCommand}"
                                IsVisible="{Binding CanGoNext}"/>
                    </StackPanel>

                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
