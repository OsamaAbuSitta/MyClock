<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:MyClock.App.ViewModels"
        x:Class="MyClock.App.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Width="220" Height="160"
        MinWidth="220" MinHeight="160"
        MaxWidth="220" MaxHeight="160"
        CanResize="False"
        Topmost="True"
        SystemDecorations="None"
        Background="Transparent"
        TransparencyLevelHint="Transparent"
        ExtendClientAreaToDecorationsHint="True">

    <Border Name="DragBorder"
            Background="#DD1E1E1E"
            CornerRadius="12"
            Padding="12 8"
            PointerPressed="OnDragBorderPressed"
            PointerMoved="OnDragBorderMoved"
            PointerReleased="OnDragBorderReleased">

        <StackPanel Spacing="4">

            <!-- Row 1: Current time + settings + close buttons -->
            <Grid ColumnDefinitions="*,Auto,Auto">
                <TextBlock Grid.Column="0"
                           Text="{Binding CurrentTimeDisplay}"
                           FontSize="18"
                           FontWeight="Light"
                           Foreground="#CCFFFFFF"
                           HorizontalAlignment="Center"/>
                <Button Grid.Column="1"
                        Content="⚙"
                        Command="{Binding OpenSettingsCommand}"
                        Background="Transparent"
                        Foreground="#88FFFFFF"
                        FontSize="12"
                        Padding="2 0"
                        VerticalAlignment="Top"
                        BorderThickness="0"/>
                <Button Grid.Column="2"
                        Content="×"
                        Command="{Binding CloseCommand}"
                        Background="Transparent"
                        Foreground="#88FFFFFF"
                        FontSize="14"
                        Padding="2 0"
                        VerticalAlignment="Top"
                        BorderThickness="0"/>
            </Grid>

            <!-- Row 2: Session timer -->
            <TextBlock Text="{Binding SessionTimeDisplay}"
                       FontSize="26"
                       FontWeight="Bold"
                       Foreground="White"
                       HorizontalAlignment="Center"/>

            <!-- Row 3: Session name / status -->
            <TextBlock Text="{Binding SessionStatusDisplay}"
                       FontSize="10"
                       Foreground="#88FFFFFF"
                       HorizontalAlignment="Center"/>

            <!-- Row 4: Control buttons -->
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        Spacing="4"
                        Margin="0 4 0 0">
                <Button Content="Start"
                        Command="{Binding StartCommand}"
                        IsVisible="{Binding CanStart}"
                        FontSize="11" Padding="8 3"/>
                <Button Content="Pause"
                        Command="{Binding PauseCommand}"
                        IsVisible="{Binding CanPause}"
                        FontSize="11" Padding="8 3"/>
                <Button Content="Resume"
                        Command="{Binding ResumeCommand}"
                        IsVisible="{Binding CanResume}"
                        FontSize="11" Padding="8 3"/>
                <Button Content="Reset"
                        Command="{Binding ResetCommand}"
                        IsVisible="{Binding CanReset}"
                        FontSize="11" Padding="8 3"/>
            </StackPanel>

        </StackPanel>
    </Border>
</Window>
